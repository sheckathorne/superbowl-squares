{
  "dependencies": {
    "@tailwindcss/cli": "^4.0.6",
    "live-server": "^1.2.2",
    "tailwindcss": "^4.0.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "prettier": "^3.5.1",
    "typescript": "^5.7.3"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "start": "node dist/index.js",
